{{ define "iam_user_update_account" }}

{{ template "iam_user_basic" . }}

resource "linode_iam_user" "test_iam_user" {
    username = "{{.Username}}"
    account_access = ["account_linode_creator"]
    entity_access = [
        {
            id = linode_volume.test_volume.id
            type = "volume"
            roles = ["{{.Role}}"]
        }
    ]
}

{{ end }}
