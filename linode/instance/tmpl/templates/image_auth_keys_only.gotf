{{ define "instance_image_auth_keys_only" }}

{{ template "e2e_test_firewall" . }}

resource "linode_instance" "foobar" {
    label = "{{.Label}}"
    type = "g6-nanode-1"
    image = "{{.Image}}"
    region = "{{ .Region }}"
    authorized_keys = ["{{.PubKey}}"]
    firewall_id = linode_firewall.e2e_test_firewall.id
}

{{ end }}

