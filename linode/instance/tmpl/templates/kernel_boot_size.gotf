{{ define "instance_kernel_boot_size" }}

{{ template "e2e_test_firewall" . }}

resource "linode_instance" "foobar" {
    label = "{{.Label}}"
    type = "g6-nanode-1"
    image = "{{.Image}}"
    region = "{{ .Region }}"
    root_pass = "{{.RootPass}}"
    firewall_id = linode_firewall.e2e_test_firewall.id

    kernel = "{{ .Kernel }}"
    boot_size = {{ .BootSize }}
}

{{ end }}


