{{ define "instance_alerts_updates" }}

{{ template "e2e_test_firewall" . }}

resource "linode_instance" "foobar" {
    label = "{{.Label}}_r"
    group = "tf_test"
    type = "g6-nanode-1"
    region = "{{ .Region }}"
    alerts {
        system_alerts = []
    }
    firewall_id = linode_firewall.e2e_test_firewall.id
}

{{ end }}