{{ define "instance_disk_image_auth_keys_only" }}

resource "linode_instance" "foobar" {
    label = "{{ .Label }}"
    type = "g6-nanode-1"
    region = "{{ .Region }}"
}

resource "linode_instance_disk" "foobar" {
    label = "{{ .Label }}"
    linode_id = linode_instance.foobar.id
    size = {{ .Size }}

    image = "linode/debian12"
    authorized_keys = [
        "{{ .PubKey }}"
    ]
}

{{ end }}

